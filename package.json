{
  "name": "web",
  "version": "1.0.0",
  "description": "Interactive web-based animator for the 39C3 variable font, featuring dynamic weight interpolation and brand-compliant color modes.",
  "keywords": [],
  "homepage": "https://github.com/o1y/39c3-logo-animator#readme",
  "bugs": {
    "url": "https://github.com/o1y/39c3-logo-animator/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o1y/39c3-logo-animator.git"
  },
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "app.js",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "format": "sort-package-json && prettier --write \"**/*.{js,json,html,css}\"",
    "format:check": "sort-package-json --check && prettier --check \"**/*.{js,json,html,css}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc -p jsconfig.json --noEmit 2>&1 | grep '^src/' && exit 1 || exit 0"
  },
  "browserslist": [
    "defaults and fully supports es6-module"
  ],
  "overrides": {
    "ajv": "6.14.0",
    "dompurify": "^3.3.2",
    "lru-cache": "~11.2.7",
    "minimatch": "^3.1.4",
    "rollup": "^4.59.0"
  },
  "dependencies": {
    "alpinejs": "^3.15.11",
    "gif.js": "^0.2.0",
    "jspdf": "^4.2.1",
    "opentype.js": "https://github.com/o1y/opentype.js#ff6189bef3336b5666f1105d611cb1a437bf1c8a",
    "webm-writer": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@napi-rs/canvas": "^0.1.97",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.27",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "rollup-plugin-license": "^3.7.0",
    "sort-package-json": "^3.6.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.5",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-static-copy": "^4.0.1",
    "vitest": "^4.1.2"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "^0.28.0",
    "@rollup/rollup-linux-x64-gnu": "^4.60.1"
  }
}
